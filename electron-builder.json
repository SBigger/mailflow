{
  "appId": "ch.artis.smartis",
  "productName": "Smartis",
  "copyright": "© 2026 Artis Treuhand GmbH",
  "directories": {
    "output": "electron-dist"
  },
  "files": [
    "electron/**/*",
    "package.json"
  ],
  "extraMetadata": {
    "main": "electron/main.cjs"
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "icon": "electron/icon.ico",
    "publisherName": "Artis Treuhand GmbH",
    "signAndEditExecutable": false,
    "signingHashAlgorithms": null
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowElevation": true,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Smartis"
  },
  "asar": true,
  "asarUnpack": [
    "**/node_modules/better-sqlite3/**"
  ]
}
