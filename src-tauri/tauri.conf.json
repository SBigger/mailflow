{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Smartis",
  "version": "1.0.12",
  "identifier": "ch.artis.smartis",
  "build": {
    "beforeDevCommand": "npm run dev",
    "frontendDist": "../dist/tauri",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    },
    "publisher": "Artis Treuhand GmbH",
    "copyright": "© 2026 Artis Treuhand GmbH",
    "shortDescription": "Smartis – Kanzleisoftware",
    "longDescription": "Smartis ist die interne Kanzleisoftware der Artis Treuhand GmbH mit Offline-Unterstützung."
  }
}
